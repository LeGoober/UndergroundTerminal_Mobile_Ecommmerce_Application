# ===============================================================
# Underground Terminal - Environment Variables
# ===============================================================
# Copy this file to .env and fill in your values
# cp .env.example .env

# --- Spring Profile ---
# Options: dev (default/H2), staging (MySQL), prod (MySQL/production)
SPRING_PROFILES_ACTIVE=dev

# --- Server ---
PORT=8080

# --- Database (MySQL - used in staging & prod) ---
DB_HOST=localhost
DB_PORT=3306
DB_NAME=underground_terminal
DB_USERNAME=root
DB_PASSWORD=admin

# --- JWT ---
# Generate a strong secret: openssl rand -base64 64
JWT_SECRET=UndergroundTerminalSecretKey2024!@#$%^&*()_+
JWT_EXPIRATION=86400000

# --- Google OAuth2 ---
# Get these from: https://console.cloud.google.com/apis/credentials
GOOGLE_CLIENT_ID=YOUR_GOOGLE_CLIENT_ID
GOOGLE_CLIENT_SECRET=YOUR_GOOGLE_CLIENT_SECRET

# --- CORS ---
CORS_ORIGINS=http://localhost:8080,http://10.0.2.2:8080

# --- Logging ---
LOG_LEVEL=DEBUG

# --- Supabase (optional - for real-time features) ---
# SUPABASE_URL=https://your-project.supabase.co
# SUPABASE_ANON_KEY=your-anon-key
